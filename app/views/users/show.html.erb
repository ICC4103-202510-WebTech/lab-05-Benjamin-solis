<h1>User Details</h1>

<div class="card">
  <div class="card-body">
    <h5 class="card-title"><%= @user.first_name %> <%= @user.last_name %></h5>
    <p class="card-text">
      <strong>Email:</strong> <%= @user.email %><br>
      <strong>Created at:</strong> <%= @user.created_at %><br>
      <strong>Updated at:</strong> <%= @user.updated_at %>
    </p>
    <%= link_to "Editar Usuario", edit_user_path(@user), class: "btn btn-primary me-2" %>
    <%= link_to "Back to Users", users_path, class: "btn btn-secondary" %>
  </div>
</div>

<hr>

<h2>Chats del usuario</h2>
<ul>
  <% Chat.where("sender_id = ? OR receiver_id = ?", @user.id, @user.id).each do |chat| %>
    <li>
      Chat con 
      <% if chat.sender_id == @user.id %>
        <%= User.find(chat.receiver_id).first_name %> <%= User.find(chat.receiver_id).last_name %>
      <% else %>
        <%= User.find(chat.sender_id).first_name %> <%= User.find(chat.sender_id).last_name %>
      <% end %>
      - <%= link_to 'Ver chat', chat_path(chat) %>
    </li>
  <% end %>
</ul>

<h2>Mensajes enviados</h2>
<ul>
  <% @user.messages.each do |message| %>
    <li>
      En chat #<%= message.chat_id %>: <%= message.body %>
      - <%= link_to 'Ver mensaje', message_path(message) %>
    </li>
  <% end %>
</ul>
