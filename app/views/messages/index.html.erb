<h1>Messages</h1>

<% if @messages.blank? %>
  <div class="alert alert-info">
    No hay mensajes disponibles.
  </div>
<% else %>
  <table class="table table-striped">
    <thead>
      <tr>
        <th>ID</th>
        <th>Chat ID</th>
        <th>User ID</th>
        <th>Body</th>
        <th>Actions</th>
      </tr>
    </thead>
    <tbody>
      <% @messages.each do |message| %>
        <tr>
          <td><%= message.id %></td>
          <td><%= message.chat_id %></td>
          <td><%= message.user_id %></td>
          <td><%= truncate(message.body, length: 50) %></td>
          <td>
            <%= link_to "Show", message_path(message), class: "btn btn-sm btn-primary" %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
<% end %>