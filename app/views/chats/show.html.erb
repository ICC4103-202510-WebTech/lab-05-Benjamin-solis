<h1>Chat Details</h1>

<div class="card mb-4">
  <div class="card-body">
    <h5 class="card-title">Chat #<%= @chat.id %></h5>
    <p class="card-text">
      <strong>Sender:</strong> <%= @chat.sender.first_name %> <%= @chat.sender.last_name %><br>
      <strong>Receiver:</strong> <%= @chat.receiver.first_name %> <%= @chat.receiver.last_name %><br>
      <strong>Created at:</strong> <%= @chat.created_at.strftime("%d-%m-%Y %H:%M") %><br>
      <strong>Updated at:</strong> <%= @chat.updated_at.strftime("%d-%m-%Y %H:%M") %>
    </p>

    <%= link_to "Editar chat", edit_chat_path(@chat), class: "btn btn-primary me-2" %>
    <%= link_to "Back to Chats", chats_path, class: "btn btn-secondary" %>
  </div>
</div>

<h2>Messages in this Chat</h2>
<% if @messages.any? %>
  <div class="list-group">
    <% @messages.each do |message| %>
      <div class="list-group-item">
        <div class="d-flex w-100 justify-content-between">
          <h5 class="mb-1"><strong>From:</strong> <%= message.user.first_name %> <%= message.user.last_name %></h5>
          <small><%= message.created_at.strftime("%d-%m-%Y %H:%M") %></small>
        </div>
        <p class="mb-1"><%= message.body %></p>
        <%= link_to "View Message", message_path(message), class: "btn btn-sm btn-info" %>
      </div>
    <% end %>
  </div>
<% else %>
  <p>No messages in this chat.</p>
<% end %>
